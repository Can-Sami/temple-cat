OPENAI_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
DAILY_API_KEY=

# Browser origin(s) allowed by the API CORS middleware (comma-separated).
# Local dev: http://localhost:3000
# Cloudflare Tunnel / public URL: add your HTTPS origin, e.g. https://voice.example.com
# Emergencies only: FRONTEND_ORIGIN=* (discouraged)
FRONTEND_ORIGIN=http://localhost:3000

# Per-session bot subprocess logs inside the backend container (see DEPLOY.md).
BOT_LOG_DIR=/app/logs

# Rate limiting (sliding window per client IP)
SESSION_RATE_LIMIT_MAX=30
SESSION_RATE_LIMIT_WINDOW_SECONDS=60
VALIDATE_CONFIG_RATE_LIMIT_MAX=120
VALIDATE_CONFIG_RATE_LIMIT_WINDOW_SECONDS=60

# Daily REST API retries on transient errors (1–10)
DAILY_API_MAX_ATTEMPTS=3

# Set to 1 when behind nginx/ALB/Cloudflare so X-Forwarded-For is used for limits
TRUST_PROXY_HEADERS=0

# --- Pipecat OpenTelemetry (optional addon) ---
# Docs: https://docs.pipecat.ai/api-reference/server/utilities/opentelemetry
# ENABLE_TRACING=1
# OTEL_SERVICE_NAME=temple-cat-voice-bot
# OTLP gRPC (Jaeger / default collector on 4317):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# OTEL_EXPORTER_OTLP_INSECURE=true
# HTTP OTLP (e.g. Langfuse): set protocol and endpoint per vendor docs
# OTEL_EXPORTER_OTLP_TRACES_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_ENDPOINT=https://...
# OTEL_CONSOLE_EXPORT=0
