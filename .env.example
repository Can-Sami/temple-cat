# Copy to `.env` on the server — never commit real secrets.
#
# Used ONLY for RAG embeddings now (the conversational LLM moved to KKB Gemma
# below). No trailing `>` / quotes — paste the raw sk-… key only.
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
DAILY_API_KEY=

# --- LLM: KKB Gemma (OpenAI-compatible vLLM). URL+model defaults baked into bot.py.
# NOTE: this endpoint is auth-gated (returns 401 to `dummy`) — set a REAL key.
LLM_URL=https://kkb-llm.freyavoice.ai/v1
LLM_MODEL=google/gemma-4-31B-it
LLM_API_KEY=
# --- Freya TTS (KKB, OpenAI-compatible /v1/audio/speech, returns 16kHz PCM).
# Not in this repo: supply the Freya speech endpoint + key reachable from this host.
TTS_URL=https://kkb-tts.freyavoice.ai/v1/
TTS_API_KEY=
TTS_VOICE_ID=leyla
TTS_MODEL=tts-1

# CORS: comma-separated browser origins (must include your Cloudflare/ngrok URL).
FRONTEND_ORIGIN=http://localhost:3000

# --- Help Center RAG (Qdrant)
# Set to 0 to disable retrieval (bot still runs).
RAG_ENABLED=1
# Inside Docker Compose this defaults to the `qdrant` service.
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=help_center
QDRANT_TOP_K=3
EMBEDDINGS_MODEL=text-embedding-3-small
# Optional: only if you use a reduced-dimension embedding variant.
# EMBEDDINGS_VECTOR_SIZE=

# --- Optional: Pipecat OpenTelemetry (Jaeger — use `docker compose --profile otel up -d`)
# ENABLE_TRACING=1
# OTEL_SERVICE_NAME=temple-cat-voice-bot
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# OTEL_EXPORTER_OTLP_INSECURE=true

# --- Optional tuning
# BOT_LOG_DIR=/app/logs
# DAILY_API_MAX_ATTEMPTS=3
